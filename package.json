{
  "name": "qycq-gis-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "QYCQ village GIS leadership demo frontend",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --mode test",
    "build": "tsc --noEmit && vite build",
    "build:serve": "tsc --noEmit && vite build --mode serve",
    "serve": "vite preview",
    "mock:build": "python3 scripts/build_mock_data.py",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:python": "python3 -m unittest discover -s tests/python -p 'test_*.py'",
    "test:e2e": "playwright test"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@tanstack/react-query": "^5.97.0",
    "clsx": "^2.1.1",
    "maplibre-gl": "^5.22.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.4",
    "jsdom": "^29.0.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
